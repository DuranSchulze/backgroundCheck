generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProgressStatus {
  QUEUED
  IN_PROGRESS
  ACTIVE_INVESTIGATION
  COMPLETED
  ON_HOLD
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model OrderProgress {
  id             String         @id @default(cuid())
  trackingNumber String         @unique
  overallStatus  ProgressStatus @default(QUEUED)
  summary        String?        @db.Text
  etaLabel       String?
  adminNotes     String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checks     CheckTypeProgress[]
  activities ProgressActivity[]

  @@index([overallStatus])
}

model CheckTypeProgress {
  id              String         @id @default(cuid())
  orderProgressId String
  serviceKey      String
  serviceLabel    String
  status          ProgressStatus @default(QUEUED)
  timelineLabel   String?
  notes           String?        @db.Text
  fileUrl         String?        @db.Text
  sortOrder       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderProgress OrderProgress @relation(fields: [orderProgressId], references: [id], onDelete: Cascade)
  tasks         CheckTask[]

  @@unique([orderProgressId, serviceKey])
  @@index([orderProgressId])
  @@index([serviceKey])
}

model CheckTask {
  id                  String         @id @default(cuid())
  checkTypeProgressId String
  assigneeId          String?
  title               String
  description         String?        @db.Text
  status              ProgressStatus @default(QUEUED)
  priority            TaskPriority   @default(MEDIUM)
  publicStepNumber    Int?
  dueDate             DateTime?
  notes               String?        @db.Text
  fileUrl             String?        @db.Text
  sortOrder           Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkTypeProgress CheckTypeProgress @relation(fields: [checkTypeProgressId], references: [id], onDelete: Cascade)
  assignee          StaffUser?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([checkTypeProgressId])
  @@index([assigneeId])
  @@index([status, priority])
}

model ProgressActivity {
  id              String   @id @default(cuid())
  orderProgressId String
  message         String   @db.Text
  highlight       String?
  createdAt       DateTime @default(now())

  orderProgress OrderProgress @relation(fields: [orderProgressId], references: [id], onDelete: Cascade)

  @@index([orderProgressId, createdAt])
}

model StaffUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTasks CheckTask[]

  @@index([isActive, name])
}
