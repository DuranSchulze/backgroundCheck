generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProgressStatus {
  QUEUED
  IN_PROGRESS
  ACTIVE_INVESTIGATION
  COMPLETED
  ON_HOLD
}

model OrderProgress {
  id             String         @id @default(cuid())
  trackingNumber String         @unique
  overallStatus  ProgressStatus @default(QUEUED)
  summary        String?        @db.Text
  etaLabel       String?
  adminNotes     String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checks     CheckTypeProgress[]
  activities ProgressActivity[]

  @@index([overallStatus])
}

model CheckTypeProgress {
  id              String         @id @default(cuid())
  orderProgressId String
  checkName       String
  status          ProgressStatus @default(QUEUED)
  timelineLabel   String?
  notes           String?        @db.Text
  sortOrder       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderProgress OrderProgress @relation(fields: [orderProgressId], references: [id], onDelete: Cascade)
  tasks         CheckTask[]

  @@unique([orderProgressId, checkName])
  @@index([orderProgressId])
}

model CheckTask {
  id                  String         @id @default(cuid())
  checkTypeProgressId String
  title               String
  status              ProgressStatus @default(QUEUED)
  notes               String?        @db.Text
  sortOrder           Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkTypeProgress CheckTypeProgress @relation(fields: [checkTypeProgressId], references: [id], onDelete: Cascade)

  @@index([checkTypeProgressId])
}

model ProgressActivity {
  id              String   @id @default(cuid())
  orderProgressId String
  message         String   @db.Text
  highlight       String?
  createdAt       DateTime @default(now())

  orderProgress OrderProgress @relation(fields: [orderProgressId], references: [id], onDelete: Cascade)

  @@index([orderProgressId, createdAt])
}
