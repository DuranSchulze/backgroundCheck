generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProgressStatus {
  QUEUED
  IN_PROGRESS
  ACTIVE_INVESTIGATION
  COMPLETED
  ON_HOLD
}

enum CheckCategory {
  IDENTITY_CHECKS
  VERIFICATION_SERVICES
  LEGAL_IMMIGRATION_CHECKS
  CORPORATE_FINANCIAL_CHECKS
  SPECIALIZED_CHECKS
}

model OrderProgress {
  id            String         @id @default(cuid())
  trackingNumber String        @unique
  overallStatus ProgressStatus @default(QUEUED)
  summary       String?        @db.Text
  etaLabel      String?
  adminNotes    String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checks     CheckTypeProgress[]
  activities ProgressActivity[]

  @@index([overallStatus])
}

model CheckTypeProgress {
  id              String         @id @default(cuid())
  orderProgressId String
  checkType       CheckCategory
  status          ProgressStatus @default(QUEUED)
  timelineLabel   String?
  notes           String?        @db.Text
  sortOrder       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderProgress OrderProgress @relation(fields: [orderProgressId], references: [id], onDelete: Cascade)

  @@unique([orderProgressId, checkType])
  @@index([orderProgressId])
  @@index([checkType])
}

model ProgressActivity {
  id              String   @id @default(cuid())
  orderProgressId String
  message         String   @db.Text
  highlight       String?
  createdAt       DateTime @default(now())

  orderProgress OrderProgress @relation(fields: [orderProgressId], references: [id], onDelete: Cascade)

  @@index([orderProgressId, createdAt])
}
